# ─────────────────────────────────────────────
# Crop-to-Cash Backend Environment Variables
# ─────────────────────────────────────────────

# OPTION 1: Local MongoDB (make sure mongod is running)
MONGO_URI=mongodb://localhost:27017/croptocash

# OPTION 2: MongoDB Atlas (cloud) — uncomment and fill in your Atlas URI
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/croptocash?retryWrites=true&w=majority

JWT_SECRET=croptocash_super_secret_2024
PORT=5000

# Optional: Add your OpenWeatherMap API key for real weather data
# Get free key at https://openweathermap.org/api
WEATHER_API_KEY=
